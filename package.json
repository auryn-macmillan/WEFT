{
  "name": "weft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "coordinator",
    "examples/weft-web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:client": "npm test -w client",
    "test:coordinator": "npm test -w coordinator",
    "demo": "npx tsx scripts/run-round.ts",
    "weft-web:dev": "pnpm --dir examples/weft-web dev",
    "weft-web:build": "pnpm --dir examples/weft-web build",
    "weft-web:test": "pnpm --dir examples/weft-web test",
    "weft-web:wasm:build": "wasm-pack build --release --target web examples/weft-web/crates/fhe-wasm --out-dir ../../packages/fhe-wasm/pkg"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "ethers": "^6.0.0"
  }
}
